{
  "version": 2,
  "installCommand": "cd frontend && npm ci",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist/client",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "^/assets/(.*)$",
      "dest": "/assets/$1"
    },
    {
      "src": "^/(.*\\.(js|css|map|png|jpg|jpeg|svg|ico|json|woff2|woff|ttf))$",
      "dest": "/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/index?pathname=$1"
    }
  ]
}
