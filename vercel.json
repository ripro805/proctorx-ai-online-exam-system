{
  "version": 2,
  "installCommand": "cd frontend && npm ci",
  "buildCommand": "cd frontend && npm run build",
  "functions": {
    "api/index2.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "\\/(.*\\.(js|css|map|png|jpg|jpeg|svg|ico|json|woff2|woff|ttf))",
      "destination": "/frontend/dist/client/$1"
    },
    {
      "source": "\\/assets\\/(.*)",
      "destination": "/frontend/dist/client/assets/$1"
    },
    {
      "source": "\\/(.*)",
      "destination": "/api/index2?pathname=$1"
    }
  ]
}
